{
  "rewrites": [
    { "source": "/parcours", "destination": "/parcours/index.html" },
    { "source": "/admin",    "destination": "/admin/index.html" },
    { "source": "/landing",  "destination": "/landing/index.html" },
    { "source": "/",         "destination": "/admin/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control",     "value": "no-store, no-cache, must-revalidate, max-age=0, s-maxage=0" },
        { "key": "Surrogate-Control", "value": "no-store" },
        { "key": "Pragma",            "value": "no-cache" },
        { "key": "Expires",           "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0, s-maxage=0" }
      ]
    }
  ]
}
